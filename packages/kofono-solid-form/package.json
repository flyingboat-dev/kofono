{
    "name": "@kofono/solid-form",
    "private": true,
    "version": "0.2.0",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "source": "./src/index.ts",
    "exports": {
        "solid": "./dist/index.jsx",
        "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": ["dist", "README.md", "LICENSE.md"],
    "scripts": {
        "build": "pnpm build:ts && pnpm build:tsup",
        "build:ts": "tsc -p tsconfig.json",
        "build:tsup": "tsup --config tsup.config.ts",
        "build:watch": "tsup --config tsup.config.ts --watch",
        "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
        "dev": "vite serve dev",
        "check": "pnpm biome check",
        "check:fix": "pnpm check --write",
        "format": "pnpm biome format",
        "old:build:vite": "vite build",
        "preview": "vite preview",
        "test": "vitest"
    },
    "dependencies": {
        "@solid-primitives/i18n": "2.2.1",
        "@solid-primitives/scheduled": "1.5.3",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "kofono": "workspace:*",
        "solid-js": "^1.9.12"
    },
    "peerDependencies": {
        "solid-js": "^1.9.12",
        "tailwindcss": "^4.2.2"
    },
    "devDependencies": {
        "@solidjs/testing-library": "^0.8.10",
        "@tailwindcss/postcss": "^4.2.2",
        "@tailwindcss/vite": "^4.2.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.6.0",
        "daisyui": "^5.5.19",
        "jsdom": "^29.0.2",
        "solid-icons": "^1.2.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "tailwindcss-animate": "^1.0.7",
        "tslib": "^2.8.1",
        "tsup": "^8.5.1",
        "tsup-preset-solid": "^2.2.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.8",
        "vite-plugin-solid": "^2.11.12",
        "vitest": "^4.1.4"
    },
    "typesVersions": {},
    "engines": {
        "node": ">=20",
        "pnpm": ">=10.0.0"
    },
    "module": "./dist/index.js",
    "browser": {}
}
