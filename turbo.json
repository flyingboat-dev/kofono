{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "stream-with-experimental-timestamps",
    "tasks": {
        "build": {
            "cache": true,
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**"]
        },
        "build:editor": {
            "cache": false,
            "outputs": ["dist/**"]
        },
        "build:watch": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**"],
            "persistent": true
        },
        "clean": {
            "cache": false
        },
        "dev": {
            "cache": false,
            "dependsOn": ["^build"],
            "persistent": true
        },
        "doc": {
            "cache": false,
            "dependsOn": ["^build", "^build:editor"],
            "persistent": true
        },
        "format": {},
        "check": {
            "cache": true
        },
        "check:fix": {
            "cache": false
        },
        "test": {
            "cache": true,
            "dependsOn": ["^test"]
        },
        "prepublish": {
            "cache": false
        }
    }
}
