{
    "name": "kofono",
    "version": "0.9.0",
    "description": "Kofono Headless Form Engine Library",
    "keywords": [
        "form",
        "headless",
        "json",
        "schema",
        "validation",
        "typescript"
    ],
    "author": "Francois Lajoie",
    "license": "Apache-2.0",
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com:kofono/kofono.git",
        "directory": "packages/kofono"
    },
    "files": ["dist", "README.md", "LICENSE.md"],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "build:watch": "tsc -p tsconfig.json -w",
        "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
        "coverage": "vitest run --coverage",
        "check": "pnpm biome check",
        "check:fix": "pnpm check --write",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "prepublish": "pnpm check:fix && pnpm build"
    },
    "dependencies": {
        "date-fns": "4.1.0"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@vitest/coverage-v8": "^4.1.4",
        "@vitest/ui": "^4.1.4",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.4"
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=10.0.0"
    }
}
